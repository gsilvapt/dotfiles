{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet[1m]",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "theme": "dark-daltonized",
  "feedbackSurveyState": {
    "lastShownTime": 1754040862617
  },
  "permissions": {
    "allow": [
      "Read",
      "WebFetch",
      "Bash(go build)",
      "Bash(go build:*)",
      "Bash(go test)",
      "Bash(go test:*)",
      "Bash(*:-h)",
      "Bash(*:--help)"
    ],
    "ask": [
      "Edit",
      "Write",
      "MultiEdit",
      "NotebookEdit",
      "Bash"
    ]
  }
}
